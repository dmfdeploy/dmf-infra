---
# Namespace, ServiceAccount, and ClusterRoleBinding for the in-cluster
# ansible runner pods. Rendered by the ansible-runner role.
apiVersion: v1
kind: Namespace
metadata:
  name: {{ ansible_runner_namespace }}
  labels:
    app.kubernetes.io/name: ansible-runner
    app.kubernetes.io/managed-by: dmf-ansible-runner-role
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ ansible_runner_service_account }}
  namespace: {{ ansible_runner_namespace }}
  labels:
    app.kubernetes.io/name: ansible-runner
    app.kubernetes.io/managed-by: dmf-ansible-runner-role
---
# Spike RBAC: cluster-admin. See defaults/main.yml header for the
# scope-narrowing follow-up.
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: {{ ansible_runner_service_account }}-{{ ansible_runner_namespace }}
  labels:
    app.kubernetes.io/name: ansible-runner
    app.kubernetes.io/managed-by: dmf-ansible-runner-role
subjects:
  - kind: ServiceAccount
    name: {{ ansible_runner_service_account }}
    namespace: {{ ansible_runner_namespace }}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: {{ ansible_runner_cluster_role }}
