      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      authentication_flow: !Find [authentik_flows.flow, [slug, dmf-passkey-login]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      client_type: confidential
      access_code_validity: {{ authentik_oidc_access_code_validity | default('minutes=1', true) | to_json }}
      access_token_validity: {{ authentik_oidc_access_token_validity | default('minutes=15', true) | to_json }}
      refresh_token_validity: {{ authentik_oidc_refresh_token_validity | default('hours=8', true) | to_json }}
