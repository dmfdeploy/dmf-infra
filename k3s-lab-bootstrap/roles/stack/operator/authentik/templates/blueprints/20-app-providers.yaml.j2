      access_token_validity: {{ authentik_oidc_access_token_validity | default('minutes=15', true) | to_json }}
      refresh_token_validity: {{ authentik_oidc_refresh_token_validity | default('hours=8', true) | to_json }}
      redirect_uris:
        - matching_mode: strict
          url: {{ (_librenms_base_url ~ '/auth/authentik/callback') | to_json }}
      include_claims_in_id_token: true
      issuer_mode: global
      signing_key: !Find [authentik_crypto.certificatekeypair, [name, authentik Self-signed Certificate]]
      pkce_required: true
      sub_mode: user_username
      property_mappings:
        - !Find [authentik_core.propertymapping, [managed, "goauthentik.io/providers/oauth2/scope-openid"]]
        - !Find [authentik_core.propertymapping, [managed, "goauthentik.io/providers/oauth2/scope-email"]]
        - !Find [authentik_core.propertymapping, [managed, "goauthentik.io/providers/oauth2/scope-profile"]]
        - !Find [authentik_providers_oauth2.scopemapping, [name, DMF groups]]

  - model: authentik_core.application
    id: app-librenms
    state: present
    identifiers:
      slug: librenms
    attrs:
      name: LibreNMS
      slug: librenms
      provider: !Find [authentik_providers_oauth2.oauth2provider, [name, LibreNMS]]
      meta_launch_url: {{ (_librenms_base_url ~ '/') | to_json }}
      meta_description: DMF network monitoring
      open_in_new_tab: true

  # ── Grafana ──────────────────────────────────────────────────────────────

  - model: authentik_providers_oauth2.oauth2provider
    id: oidc-grafana
    state: present
    identifiers:
      name: Grafana
    attrs:
      name: Grafana
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      authentication_flow: !Find [authentik_flows.flow, [slug, dmf-passkey-login]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      client_type: confidential
      access_code_validity: {{ authentik_oidc_access_code_validity | default('minutes=1', true) | to_json }}
      access_token_validity: {{ authentik_oidc_access_token_validity | default('minutes=15', true) | to_json }}
      refresh_token_validity: {{ authentik_oidc_refresh_token_validity | default('hours=8', true) | to_json }}
      redirect_uris:
        - matching_mode: strict
          url: {{ (_grafana_base_url ~ '/login/generic_oauth') | to_json }}
      include_claims_in_id_token: true
      issuer_mode: global
      signing_key: !Find [authentik_crypto.certificatekeypair, [name, authentik Self-signed Certificate]]
      pkce_required: true
      sub_mode: user_username
      property_mappings:
