# yaml-language-server: $schema=https://goauthentik.io/blueprints/schema.json
version: 1
metadata:
  name: dmf-passwordless-bootstrap
  labels:
    blueprints.goauthentik.io/description: DMF passwordless bootstrap and passkey login flows
entries:
  # Dedicated passkey-only authentication flow used by the default login page's
  # passwordless link and by passkey autofill/conditional UI.
  - model: authentik_stages_authenticator_validate.authenticatorvalidatestage
    id: dmf-passkey-login-validation
    state: present
    identifiers:
      name: dmf-passkey-login-validation
    attrs:
      name: dmf-passkey-login-validation
      not_configured_action: deny
      device_classes:
        - webauthn
      webauthn_user_verification: required

  - model: authentik_stages_user_login.userloginstage
    id: dmf-passkey-login-user-login
    state: present
    identifiers:
      name: dmf-passkey-login-user-login
    attrs:
      name: dmf-passkey-login-user-login

  - model: authentik_flows.flow
    id: dmf-passkey-login-flow
    state: present
    identifiers:
      slug: {{ authentik_bootstrap_passkey_login_flow_slug | to_json }}
    attrs:
      name: DMF passkey login
      slug: {{ authentik_bootstrap_passkey_login_flow_slug | to_json }}
      title: Sign in with passkey
      designation: authentication
      authentication: none

  - model: authentik_flows.flowstagebinding
    id: dmf-passkey-login-validation-binding
    state: present
    identifiers:
      target: !KeyOf dmf-passkey-login-flow
      stage: !KeyOf dmf-passkey-login-validation
      order: 10
    attrs:
      target: !KeyOf dmf-passkey-login-flow
      stage: !KeyOf dmf-passkey-login-validation
      order: 10
      evaluate_on_plan: false
      re_evaluate_policies: true

  - model: authentik_flows.flowstagebinding
    id: dmf-passkey-login-user-login-binding
    state: present
    identifiers:
      target: !KeyOf dmf-passkey-login-flow
      stage: !KeyOf dmf-passkey-login-user-login
      order: 100
    attrs:
      target: !KeyOf dmf-passkey-login-flow
      stage: !KeyOf dmf-passkey-login-user-login
      order: 100
      evaluate_on_plan: false
      re_evaluate_policies: true

  # Invitation-gated first passkey enrollment for the pre-seeded bootstrap
  # operator user. The invite token is generated by Ansible after this blueprint
  # is applied and stored in OpenBao.
  - model: authentik_stages_invitation.invitationstage
    id: dmf-bootstrap-passkey-invitation
    state: present
    identifiers:
      name: dmf-bootstrap-passkey-invitation
    attrs:
      name: dmf-bootstrap-passkey-invitation
      continue_flow_without_invitation: false

  - model: authentik_stages_user_login.userloginstage
    id: dmf-bootstrap-passkey-user-login
    state: present
    identifiers:
      name: dmf-bootstrap-passkey-user-login
    attrs:
      name: dmf-bootstrap-passkey-user-login

  - model: authentik_flows.flow
    id: dmf-bootstrap-passkey-enrollment-flow
    state: present
    identifiers:
      slug: {{ authentik_bootstrap_passkey_enrollment_flow_slug | to_json }}
    attrs:
      name: DMF bootstrap passkey enrollment
      slug: {{ authentik_bootstrap_passkey_enrollment_flow_slug | to_json }}
      title: Enroll DMF bootstrap passkey
      designation: enrollment
      authentication: require_unauthenticated

  - model: authentik_flows.flowstagebinding
    id: dmf-bootstrap-passkey-invitation-binding
    state: present
    identifiers:
      target: !Find [authentik_flows.flow, [slug, {{ authentik_bootstrap_passkey_enrollment_flow_slug }}]]
      stage: !KeyOf dmf-bootstrap-passkey-invitation
      order: 5
    attrs:
      target: !Find [authentik_flows.flow, [slug, {{ authentik_bootstrap_passkey_enrollment_flow_slug }}]]
      stage: !KeyOf dmf-bootstrap-passkey-invitation
      order: 5
      evaluate_on_plan: true
      re_evaluate_policies: true

  - model: authentik_flows.flowstagebinding
    id: dmf-bootstrap-passkey-setup-binding
    state: present
    identifiers:
      target: !Find [authentik_flows.flow, [slug, {{ authentik_bootstrap_passkey_enrollment_flow_slug }}]]
      stage: !Find [authentik_stages_authenticator_webauthn.authenticatorwebauthnstage, [name, dmf-webauthn-stage]]
      order: 20
    attrs:
      target: !Find [authentik_flows.flow, [slug, {{ authentik_bootstrap_passkey_enrollment_flow_slug }}]]
      stage: !Find [authentik_stages_authenticator_webauthn.authenticatorwebauthnstage, [name, dmf-webauthn-stage]]
      order: 20
      evaluate_on_plan: false
      re_evaluate_policies: true

  # Resolve the invited operator into the flow's pending_user WITHOUT a username
  # prompt. The identification stage used to do this (and prompted); it was
  # removed (see tombstones below). The invitation stage merges its fixed_data
  # ({username,email,name}) into prompt_data on redeem, so this expression policy
  # — bound to the WebAuthn setup binding with re_evaluate_policies/evaluate_on_plan
  # already set above so it runs at execution time, after the invitation stage —
  # looks the user up and sets pending_user. Without this the WebAuthn enroll
  # stage gets AnonymousUser and crashes (get_challenge -> user.uid).
  - model: authentik_policies_expression.expressionpolicy
    id: dmf-bootstrap-passkey-resolve-user
    state: present
    identifiers:
      name: dmf-bootstrap-passkey-resolve-user
    attrs:
      name: dmf-bootstrap-passkey-resolve-user
      execution_logging: true
      expression: |
        prompt_data = request.context.get("prompt_data", {}) or {}
        username = prompt_data.get("username")
        if not username:
            invitation = request.context.get("invitation")
            if invitation is not None:
                fixed = getattr(invitation, "fixed_data", None) or {}
                username = fixed.get("username")
        if not username:
            return False
        from authentik.core.models import User
        user = User.objects.filter(username=username).first()
        if user is None:
            return False
        # The PolicyRequest context is a copy; the executor reads pending_user
        # from the live FlowPlan, so write through to flow_plan.context (the
        # real object passed by reference). Set both to be safe.
        flow_plan = request.context.get("flow_plan")
        if flow_plan is not None:
            flow_plan.context["pending_user"] = user
        request.context["pending_user"] = user
        return True

  - model: authentik_policies.policybinding
    id: dmf-bootstrap-passkey-resolve-user-binding
    state: present
    identifiers:
      target: !KeyOf dmf-bootstrap-passkey-setup-binding
      policy: !KeyOf dmf-bootstrap-passkey-resolve-user
      order: 0
    attrs:
      target: !KeyOf dmf-bootstrap-passkey-setup-binding
      policy: !KeyOf dmf-bootstrap-passkey-resolve-user
      order: 0

  - model: authentik_flows.flowstagebinding
    id: dmf-bootstrap-passkey-user-login-binding
    state: present
    identifiers:
      target: !Find [authentik_flows.flow, [slug, {{ authentik_bootstrap_passkey_enrollment_flow_slug }}]]
      stage: !KeyOf dmf-bootstrap-passkey-user-login
      order: 100
    attrs:
      target: !Find [authentik_flows.flow, [slug, {{ authentik_bootstrap_passkey_enrollment_flow_slug }}]]
      stage: !KeyOf dmf-bootstrap-passkey-user-login
      order: 100
      evaluate_on_plan: false
      re_evaluate_policies: true

  # Make the standard login screen passkey-first once a discoverable passkey
  # exists. Password remains available for break-glass and akadmin only.
  - model: authentik_stages_identification.identificationstage
    id: default-authentication-identification-passkey
    state: present
    identifiers:
      name: default-authentication-identification
    attrs:
      user_fields:
        - username
        - email
      webauthn_stage: !KeyOf dmf-passkey-login-validation
      passwordless_flow: !KeyOf dmf-passkey-login-flow
      enrollment_flow: !Find [authentik_flows.flow, [slug, {{ authentik_bootstrap_passkey_enrollment_flow_slug }}]]

  # Brand-wide passkey-first default (ADR-0015 amendment 2026-05-29). Patch the
  # built-in default brand so the Authentik portal and any SSO redirect that
  # does not pin its own authentication_flow lands directly on the passkey
  # picker (dmf-passkey-login: WebAuthn-only, no identification/username stage).
  # state: present with the domain identifier patches only flow_authentication;
  # other brand settings (branding title/logo, recovery flow) are left intact.
  # Break-glass invariant: default-authentication-flow stays DEFINED (it is no
  # longer any brand/provider default) so akadmin/break-glass can still reach
  # the username+password page via its direct URL
  # /if/flow/default-authentication-flow/ .
  - model: authentik_brands.brand
    id: default-brand-passkey-first
    state: present
    identifiers:
      domain: authentik-default
    attrs:
      flow_authentication: !KeyOf dmf-passkey-login-flow

  # Tombstones: purge the removed identification stage and its binding from
  # existing envs where they were applied before the present entries were
  # dropped (commit 4328786). Blueprints don't auto-prune vanished entries;
  # explicit state:absent is required. On a fresh env these are no-ops.
  # Binding MUST precede the stage (FK dependency).
  - model: authentik_flows.flowstagebinding
    id: dmf-bootstrap-passkey-identification-tombstone
    state: absent
    identifiers:
      target: !Find [authentik_flows.flow, [slug, {{ authentik_bootstrap_passkey_enrollment_flow_slug }}]]
      stage: !Find [authentik_stages_identification.identificationstage, [name, dmf-bootstrap-passkey-identification]]
      order: 10

  - model: authentik_stages_identification.identificationstage
    id: dmf-bootstrap-passkey-identification-tombstone
    state: absent
    identifiers:
      name: dmf-bootstrap-passkey-identification
