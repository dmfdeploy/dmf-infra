apiVersion: v1
kind: ConfigMap
metadata:
  name: grafana-custom-dashboards
  namespace: {{ grafana_namespace }}
  labels:
    grafana_dashboard: "1"
data:
  k8s-views-global.json: |
{{ lookup('file', role_path + '/files/k8s-views-global.json') | indent(4, first=True) }}
  k8s-views-nodes.json: |
{{ lookup('file', role_path + '/files/k8s-views-nodes.json') | indent(4, first=True) }}
  k8s-views-namespaces.json: |
{{ lookup('file', role_path + '/files/k8s-views-namespaces.json') | indent(4, first=True) }}
  k8s-views-pods.json: |
{{ lookup('file', role_path + '/files/k8s-views-pods.json') | indent(4, first=True) }}
